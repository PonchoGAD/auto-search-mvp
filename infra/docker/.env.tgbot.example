# =============================================================
# TG BOT ENV — скопируй в .env.tgbot и заполни все значения
# Все секреты только на сервере, этот файл только шаблон
# =============================================================

# ---- Telegram Bot (нужен BOT_TOKEN для aiogram и TELEGRAM_BOT_TOKEN для bot-api/worker) ----
BOT_TOKEN=<токен от @BotFather>
BOT_USERNAME=<username бота без @>
TELEGRAM_BOT_TOKEN=<тот же токен, что BOT_TOKEN>
TELEGRAM_BOT_USERNAME=<тот же username, что BOT_USERNAME>

# ---- Bot API ----
API_HOST=0.0.0.0
API_PORT=8100
BOT_API_PREFIX=/api/v1
BOT_INTERNAL_PREFIX=/internal

# ---- Внутренние URL (между контейнерами) ----
BOT_API_BASE_URL=http://bot-api:8100

# ---- Search Core (auto-search-api через shared docker network) ----
SEARCH_API_BASE_URL=http://auto-search-api:8000
SEARCH_API_PREFIX=/api/v1
SEARCH_API_KEY=<значение API_KEY из infra/docker/.env.prod>
SEARCH_API_TIMEOUT_SEC=20.0
SEARCH_API_RETRIES=3
SEARCH_API_RETRY_DELAY_SEC=1.0

# ---- Shared секрет: bot ↔ bot-api ↔ worker ----
# python -c "import secrets; print(secrets.token_hex(32))"
INTERNAL_API_KEY=<минимум 32 символа>

# ---- JWT (для bot-api) ----
# python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=<минимум 32 символа>
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=43200

# ---- Bot Postgres (стандартные имена — postgres читает напрямую) ----
POSTGRES_DB=auto_search_bot
POSTGRES_USER=bot
POSTGRES_PASSWORD=<придумать пароль>
DATABASE_URL=postgresql+psycopg2://bot:<POSTGRES_PASSWORD>@bot-postgres:5432/auto_search_bot

# ---- Лимиты (free tier) ----
FREE_DAILY_SEARCH_LIMIT=25
FREE_SAVED_SEARCHES_LIMIT=3
FREE_FAVORITES_LIMIT=50

# ---- Пагинация ----
SEARCH_RESULTS_PER_PAGE=3
FAVORITES_PER_PAGE=5
SAVED_SEARCHES_PER_PAGE=5

# ---- Throttle для бота ----
THROTTLE_SEARCH_SEC=1.0
THROTTLE_CALLBACK_SEC=0.3

# ---- Оплата (по умолчанию stub — без реальных платежей) ----
PAYMENT_PROVIDER=stub
PAYMENT_STUB_SUCCESS_ENABLED=false

# ---- Алерты по сохранённым поискам ----
ALERTS_BATCH_SIZE=100
ALERTS_MATCH_LIMIT_PER_SEARCH=30
ALERTS_MAX_SAVED_SEARCHES_PER_RUN=100
ALERTS_MAX_ITEMS_PER_MESSAGE=5
ALERTS_MAX_NEW_ITEMS_PER_SEARCH=20

# ---- Worker планировщик ----
SCHEDULER_POLL_INTERVAL_SEC=300
SCHEDULER_RUN_ON_STARTUP=true

# ---- Подписки ----
SUBSCRIPTION_EXPIRY_LOOKAHEAD_DAYS=3

# ---- Администраторы ----
ADMIN_TELEGRAM_IDS_RAW=<telegram_user_id через запятую, или оставить пустым>

# ---- Окружение ----
APP_ENV=production
DEBUG=false
LOG_LEVEL=INFO
SECURITY_STRICT_ENV=true

# ---- CORS (bot-api) ----
CORS_ORIGINS_RAW=*
