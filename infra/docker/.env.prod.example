# =============================================================
# SEARCH CORE ENV — скопируй в .env.prod и заполни значения
# =============================================================

# ---- PostgreSQL ----
DATABASE_URL=postgresql+psycopg2://auto:<POSTGRES_PASSWORD>@postgres:5432/auto_search
POSTGRES_PASSWORD=<придумать пароль>

# ---- Redis ----
REDIS_URL=redis://redis:6379/0

# ---- OpenAI (эмбеддинги) ----
OPENAI_API_KEY=<sk-proj-...>
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small

# ---- API Key (для nginx и tg-bot) ----
API_KEY=<python -c "import secrets; print(secrets.token_hex(32))">

# ---- Qdrant ----
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=auto_search_chunks

# ---- Reranker ----
RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# ---- Окружение ----
ENV=production
DEBUG=false
ALLOW_DEV_SEED=0

# ---- Telegram Ingest (опционально) ----
# TG_API_ID=
# TG_API_HASH=
# TG_SESSION_STRING=
# DISABLE_TELEGRAM=true

# ---- Интеграция с bot-api для динамического списка каналов ----
# Позволяет ingest-worker загружать каналы из БД бота, управляемых через /admin.
# BOT_API_INTERNAL_URL = адрес bot-api в shared сети (auto-search-bot-api)
# BOT_API_INTERNAL_KEY = то же значение, что INTERNAL_API_KEY в .env.tgbot
# BOT_API_INTERNAL_URL=http://auto-search-bot-api:8100
# BOT_API_INTERNAL_KEY=<то же значение что INTERNAL_API_KEY в .env.tgbot>
